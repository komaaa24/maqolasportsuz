BOT_TOKEN=123456:telegram-bot-token
ADMIN_CHAT_ID=123456789

# Payme
PAYME_MERCHANT_ID=merchant_id_from_payme
PAYME_LOGIN=Paycom
PAYME_MODE=production
PAYME_PASSWORD=production_key_password_from_payme
PAYME_PASSWORD_TEST=test_key_password_from_payme
PAYME_CHECKOUT_URL=https://checkout.paycom.uz
PAYME_RETURN_URL=https://t.me/your_bot_username

# Merchant API endpoint for Payme checkout window.
# Configure this URL in Payme Business:
PORT=8382
PAYME_MERCHANT_API_PATH=/api/payme
PAYME_MERCHANT_API_LOGIN=
# Optional. If empty, the app uses PAYME_PASSWORD in production and PAYME_PASSWORD_TEST in test mode.
PAYME_MERCHANT_API_KEY=

# Payment amount is in UZS. The app converts it to tiyin for Payme.
SUBMISSION_PRICE_UZS=50000

# Optional receipt metadata. Replace with your real fiscal values if required.

# Runtime storage
DATA_DIR=./data
MAX_FILE_SIZE_MB=20
