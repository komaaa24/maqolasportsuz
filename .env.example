BOT_TOKEN=123456:telegram-bot-token
ADMIN_CHAT_ID=123456789

# Payme
PAYME_MERCHANT_ID=merchant_id_from_payme
PAYME_PLAN_ID=article_review
PAYME_LOGIN=Paycom
PAYME_MODE=production
PAYME_PASSWORD=production_key_password_from_payme
PAYME_PASSWORD_TEST=test_key_password_from_payme
PAYME_SUBSCRIBE_API_URL=https://checkout.paycom.uz/api

# Payment amount is in UZS. The app converts it to tiyin for Payme.
SUBMISSION_PRICE_UZS=50000

# Optional receipt metadata. Replace with your real fiscal values if required.
PAYME_SERVICE_TITLE=Maqola tekshirish xizmati
PAYME_DETAIL_CODE=10305001001000000
PAYME_DETAIL_PACKAGE_CODE=123456
PAYME_DETAIL_VAT_PERCENT=0

# Runtime storage
DATABASE_URL=postgres://postgres:password@localhost:5432/maqola
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Telegram Web App for card input. These URLs must be public HTTPS.
WEB_APP_URL=https://programmsoft.uz/sports_web.php
WEB_APP_API_URL=https://programmsoft.uz/sports_pay.php
WEB_APP_PORT=3000
